```gitignore
# ========== Unity Generated Folders ==========
[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
UserSettings/
MemoryCaptures/
Recordings/

# ========== Visual Studio / VS Code ==========
.vs/
.vscode/
.idea/

# ========== Auto Generated Solution / Project Files ==========
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# ========== OS Files ==========
.DS_Store
Thumbs.db
desktop.ini

# ========== Crash / Debug ==========
sysinfo.txt
*.stacktrace

# ========== Package Cache ==========
/Library/PackageCache/

# ========== Ignore Builds ==========
/Build/
/Builds/

# ========== But Keep Important Unity Folders ==========
!Assets/
!Packages/
!ProjectSettings/
```
